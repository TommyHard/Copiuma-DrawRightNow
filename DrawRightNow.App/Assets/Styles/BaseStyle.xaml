<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctt="clr-namespace:DrawRightNow.App.Assets.Tooltip">

    <FontFamily x:Key="Copiuma-Regular">pack://application:,,,/Assets/Fonts/Copiuma-Regular.otf#Copiuma</FontFamily>

    <!-- Global Style -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource Copiuma-Regular}" />
    </Style>
    
    <Style TargetType="{x:Type Label}">
        <Setter Property="FontFamily" Value="{StaticResource Copiuma-Regular}" />
    </Style>

    <Style x:Key="FocusVisualStyle" TargetType="{x:Type Control}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border Margin="-1"
                            CornerRadius="3"
                            BorderThickness="2"
                            BorderBrush="#009BFF">
                        <Border BorderThickness="1"
                                CornerRadius="2"
                                BorderBrush="#101010"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background"                   Value="#181818"/>
        <Setter Property="BorderBrush"                  Value="#3E3E3E"/>
        <Setter Property="BorderThickness"              Value="1"/>
        <Setter Property="Foreground"                   Value="#FFE7E7E7"/>
        <Setter Property="FontSize"                     Value="14"/>
        <Setter Property="Padding"                      Value="12 8"/>
        <Setter Property="Placement"                    Value="Custom"/>
        <Setter Property="HorizontalOffset"             Value="0"/>
        <Setter Property="VerticalOffset"               Value="0"/>
        <Setter Property="OverridesDefaultStyle"        Value="True"/>
        <Setter Property="SnapsToDevicePixels"          Value="True"/>
        <Setter Property="FontFamily"                   Value="{DynamicResource Copiuma-Regular}"/>
        <Setter Property="CustomPopupPlacementCallback" Value="{x:Static ctt:CalloutToolTipPlacement.CenterBelowCallback}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">

                    <Border Background="Transparent"
                            Padding="12 2 12 12"
                            SnapsToDevicePixels="True">

                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="ShadowHost"
                                    Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    SnapsToDevicePixels="True"
                                    IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14"
                                                      ShadowDepth="3"
                                                      Direction="270"
                                                      Opacity="0.3"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="Bubble"
                                    Grid.Row="1"
                                    CornerRadius="3"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Border>

                            <Path Grid.Row="0"
                                  HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                  Margin="1 0 0 -1"
                                  SnapsToDevicePixels="True"
                                  Fill="{TemplateBinding Background}"
                                  Data="M -2,10 L 7,2 L 16,10 Z"/>

                            <Path Grid.Row="0"
                                  HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                  Margin="2 0 0 -1"
                                  SnapsToDevicePixels="True"
                                  Stroke="{TemplateBinding BorderBrush}"
                                  StrokeThickness="{TemplateBinding BorderThickness}"
                                  StrokeStartLineCap="Square"
                                  StrokeEndLineCap="Square"
                                  StrokeLineJoin="Miter"
                                  Data="M -2,10 L 7,2 L 15,10"/>
                        </Grid>
                    </Border>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>