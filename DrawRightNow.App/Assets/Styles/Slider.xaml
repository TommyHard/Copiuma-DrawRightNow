<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Decrease -->
    <Style x:Key="SliderDecreaseButtonWithEmphasis" TargetType="{x:Type RepeatButton}">
        <Setter Property="VerticalAlignment"        Value="Center"/>
        <Setter Property="Height"                   Value="22"/>
        <Setter Property="MinHeight"                Value="22"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="Focusable"                Value="False"/>
        <Setter Property="IsTabStop"                Value="False"/>
        <Setter Property="Margin"                   Value="0 0 -11 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Grid Height="22" 
                          VerticalAlignment="Center" 
                          SnapsToDevicePixels="True">
                        <Border x:Name="DecreaseBackground"
                                Height="6"
                                VerticalAlignment="Center"
                                Background="#FFFFFF"
                                CornerRadius="3"
                                Opacity="1"/>
                        <Border x:Name="EmphasisOverlay"
                                Height="6"
                                VerticalAlignment="Center"
                                CornerRadius="3 0 0 3"
                                Background="#009BFF"
                                Opacity="0"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=IsMouseOver}" Value="True">
                            <Setter TargetName="EmphasisOverlay" 
                                    Property="Opacity" 
                                    Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=IsKeyboardFocusWithin}" Value="True">
                            <Setter TargetName="EmphasisOverlay" 
                                    Property="Opacity" 
                                    Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Value}" Value="100">
                            <Setter TargetName="DecreaseBackground" 
                                    Property="CornerRadius" 
                                    Value="3"/>
                            <Setter TargetName="EmphasisOverlay"    
                                    Property="CornerRadius" 
                                    Value="3"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Value}" Value="0">
                            <Setter TargetName="DecreaseBackground" 
                                    Property="Opacity" 
                                    Value="0"/>
                            <Setter TargetName="EmphasisOverlay"    
                                    Property="Opacity" 
                                    Value="0"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Increase -->
    <Style x:Key="SliderIncreaseButtonBase"     TargetType="{x:Type RepeatButton}">
        <Setter Property="VerticalAlignment"    Value="Center"/>
        <Setter Property="Height"               Value="22"/>
        <Setter Property="MinHeight"            Value="22"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Background"           Value="#4D4D4D"/>
        <Setter Property="IsTabStop"            Value="False"/>
        <Setter Property="Focusable"            Value="False"/>
        <Setter Property="Margin"               Value="-11 0 0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Grid Height="22" 
                          VerticalAlignment="Center" SnapsToDevicePixels="True">
                        <Border x:Name="IncreaseBackground"
                                Height="6"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Value}" Value="100">
                            <Setter TargetName="IncreaseBackground" 
                                    Property="Opacity" 
                                    Value="0"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Core Style -->
    <Style x:Key="BlueAccentSliderStyle"    TargetType="{x:Type Slider}">
        <Setter Property="Height"           Value="32"/>
        <Setter Property="MinWidth"         Value="100"/>
        <Setter Property="ToolTip"          Value="{x:Null}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisualStyle}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1"
                                   Width="25"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#FFE7E7E7"
                                   Focusable="False"
                                   IsHitTestVisible="False"
                                   Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, StringFormat={}{0:0}}"/>

                        <Grid Grid.Column="0"
                              Height="22"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              Margin="5 0">

                            <Track x:Name="PART_Track"
                                   Focusable="False"
                                   VerticalAlignment="Center">
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderIncreaseButtonBase}"
                                                  Panel.ZIndex="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderDecreaseButtonWithEmphasis}"
                                                  Panel.ZIndex="0"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb x:Name="PART_Thumb"
                                           Width="16"
                                           Height="16"
                                           Focusable="False"
                                           IsTabStop="False"
                                           Panel.ZIndex="10"
                                           Opacity="0"
                                           IsHitTestVisible="True">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Grid Width="{TemplateBinding Width}"
                                                      Height="{TemplateBinding Height}"
                                                      SnapsToDevicePixels="True"
                                                      Background="Transparent">
                                                    <Ellipse Fill="#FFFFFF" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseCaptureWithin" Value="True">
                            <Setter TargetName="PART_Thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_Thumb" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>