    <Style x:Key="FlatButton"                           TargetType="{x:Type Button}">
        <Setter Property="Height"                       Value="35"/>
        <Setter Property="Margin"                       Value="2"/>
        <Setter Property="HorizontalContentAlignment"   Value="Center"/>
        <Setter Property="VerticalContentAlignment"     Value="Center"/>
        <Setter Property="BorderThickness"              Value="2"/>
        <Setter Property="Padding"                      Value="0"/>
        <Setter Property="FocusVisualStyle"             Value="{StaticResource FocusVisualStyle}"/>
        <Setter Property="Foreground"                   Value="#DFE3E6"/>
        <Setter Property="FontSize"                     Value="14"/>
        <Setter Property="Cursor"                       Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="Transparent"
                            SnapsToDevicePixels="True"
                            ClipToBounds="True">
                        <Grid>
                            <Border x:Name="BaseBg">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BaseBgBrush" Color="#3E3E3E"/>
                                </Border.Background>
                            </Border>

                            <Border x:Name="FocusOverlay"
                                    Background="#44009BFF" 
                                    Opacity="0" 
                                    IsHitTestVisible="False"/>

                            <Border x:Name="PressedOverlay" 
                                    Background="#11000000"
                                    Opacity="0" 
                                    IsHitTestVisible="False"/>

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="False">
                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="PressedSB"/>
                            </Trigger.EnterActions>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="NormalSB"/>
                                <StopStoryboard BeginStoryboardName="HoverSB"/>
                                <BeginStoryboard x:Name="PressedSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedOverlay" 
                                                         Storyboard.TargetProperty="Opacity" 
                                                         To="1" 
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="NormalSB"/>
                                <BeginStoryboard x:Name="HoverSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BaseBgBrush" 
                                                        Storyboard.TargetProperty="Color" 
                                                        To="#5D5D5D" 
                                                        Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="PressedOverlay" 
                                                         Storyboard.TargetProperty="Opacity" 
                                                         To="0" 
                                                         Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="False"/>
                                <Condition Property="IsMouseOver" Value="False"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="HoverSB"/>
                                <BeginStoryboard x:Name="NormalSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BaseBgBrush" 
                                                        Storyboard.TargetProperty="Color" 
                                                        To="#3E3E3E" 
                                                        Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="PressedOverlay" 
                                                         Storyboard.TargetProperty="Opacity" 
                                                         To="0" 
                                                         Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" 
                                    Property="BorderBrush" 
                                    Value="#009BFF"/>
                            <Setter TargetName="FocusOverlay" 
                                    Property="Opacity" 
                                    Value="1"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" 
                                    Property="Opacity" 
                                    Value=".4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconControlCheckBoxStyle"             TargetType="{x:Type CheckBox}">
        <Setter Property="Width"                        Value="35"/>
        <Setter Property="Height"                       Value="35"/>
        <Setter Property="Margin"                       Value="2"/>
        <Setter Property="HorizontalContentAlignment"   Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"     Value="Stretch"/>
        <Setter Property="BorderThickness"              Value="0"/>
        <Setter Property="Padding"                      Value="0"/>
        <Setter Property="FocusVisualStyle"             Value="{StaticResource FocusVisualStyle}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Border x:Name="Bd"
                            CornerRadius="1"
                            SnapsToDevicePixels="True"
                            ClipToBounds="True">
                        <Border.Background>
                            <SolidColorBrush x:Name="BgBrush"
                                             Color="#3E3E3E"/>
                        </Border.Background>

                        <Viewbox Margin="8" Stretch="Uniform">
                            <Grid>
                                <!-- Unchecked icon-->
                                <Path x:Name="IconUnchecked"
                                      Data="{TemplateBinding Content}"
                                      Fill="#DFE3E6"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Visibility="Visible"/>

                                <!-- Checked icon -->
                                <Path x:Name="IconChecked"
                                      Data="{TemplateBinding Tag}"
                                      Fill="#DFE3E6"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Viewbox>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="IconUnchecked" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="IconChecked" Property="Visibility" Value="Collapsed"/>
                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="CheckedSB"/>
                            </Trigger.EnterActions>
                        </Trigger>

                        <!-- CHECKED-->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="IconUnchecked" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="IconChecked" Property="Visibility" Value="Visible"/>

                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="UncheckedNormalSB"/>
                                <StopStoryboard BeginStoryboardName="UncheckedHoverSB"/>

                                <BeginStoryboard x:Name="CheckedSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#009BFF"
                                                        Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>

                        <!-- CHECKED + Tag not empty -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="Tag" Value="{x:Null}"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="IconUnchecked" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="IconChecked" Property="Visibility" Value="Collapsed"/>
                        </MultiTrigger>

                        <!-- UNCHECKED + HOVER -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>

                            <MultiTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="UncheckedNormalSB"/>
                                <BeginStoryboard x:Name="UncheckedHoverSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#5D5D5D"
                                                        Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <!-- UNCHECKED + NOT HOVER -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="False"/>
                            </MultiTrigger.Conditions>

                            <MultiTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="UncheckedHoverSB"/>
                                <BeginStoryboard x:Name="UncheckedNormalSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#3E3E3E"
                                                        Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextControlCheckBoxStyle"             TargetType="{x:Type CheckBox}">
        <Setter Property="Margin"                       Value="2"/>
        <Setter Property="HorizontalContentAlignment"   Value="Left"/>
        <Setter Property="VerticalContentAlignment"     Value="Center"/>
        <Setter Property="BorderThickness"              Value="0"/>
        <Setter Property="Padding"                      Value="0"/>
        <Setter Property="Foreground"                   Value="#DFE3E6"/>
        <Setter Property="FocusVisualStyle"             Value="{StaticResource FocusVisualStyle}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Bd"
                                Grid.Column="0"
                                Width="24" Height="24"
                                CornerRadius="1"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True">
                            <Border.Background>
                                <SolidColorBrush x:Name="BgBrush" Color="#3E3E3E"/>
                            </Border.Background>

                            <Path Data="{Binding Path=Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                  Fill="{TemplateBinding Foreground}"
                                  Stretch="Uniform"
                                  Margin="4"
                                  IsHitTestVisible="False"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="TextContent"
                                   Grid.Column="1"
                                   Margin="8 0 0 0"
                                   Text="{TemplateBinding Content}" 
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                   VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsChecked" Value="False">
                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="CheckedSB"/>
                            </Trigger.EnterActions>
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">

                            <Setter TargetName="Bd" 
                                    Property="Background" 
                                    Value="#009BFF"/>

                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="UncheckedNormalSB"/>
                                <StopStoryboard BeginStoryboardName="UncheckedHoverSB"/>

                                <BeginStoryboard x:Name="CheckedSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#009BFF"
                                                        Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>

                            <MultiTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="UncheckedNormalSB"/>
                                <BeginStoryboard x:Name="UncheckedHoverSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#5D5D5D"
                                                        Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsMouseOver" Value="False"/>
                            </MultiTrigger.Conditions>

                            <MultiTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="UncheckedHoverSB"/>
                                <BeginStoryboard x:Name="UncheckedNormalSB" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBrush"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#3E3E3E"
                                                        Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            <Setter TargetName="TextContent" Property="Opacity" Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
