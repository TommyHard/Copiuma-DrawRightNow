<UserControl x:Class="DrawRightNow.App.Views.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:DrawRightNow.App.Converters" 
             xmlns:views="clr-namespace:DrawRightNow.App.Views"
             Background="Transparent">

    <UserControl.Resources>
        <conv:ToolTypeToBoolConverter x:Key="ToolConv"/>
        <conv:RgbaToMediaColorConverter x:Key="RgbaToMediaColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <views:SecondaryToolbarView x:Name="SecondaryPanel">
            <views:SecondaryToolbarView.Style>
                <Style TargetType="{x:Type views:SecondaryToolbarView}">
                    <Setter Property="Grid.Row" Value="0"/>
                    <Setter Property="HorizontalAlignment" Value="Right"/>
                    <Setter Property="Margin" Value="0 0 0 8"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ToolbarDock}" Value="BottomRight">
                            <Setter Property="Grid.Row" Value="2"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0 8 0 0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolbarDock}" Value="BottomLeft">
                            <Setter Property="Grid.Row" Value="2"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Margin" Value="0 8 0 0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolbarDock}" Value="TopLeft">
                            <Setter Property="Grid.Row" Value="0"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="Margin" Value="0 0 0 8"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToolbarDock}" Value="TopRight">
                            <Setter Property="Grid.Row" Value="0"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0 0 0 8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:SecondaryToolbarView.Style>
        </views:SecondaryToolbarView>

        <Border Grid.Row="1" Grid.Column="1" 
                Style="{StaticResource CoreBorderStyle}">
            <StackPanel Orientation="Horizontal">

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource MoveTool}" 
                              Visibility="{Binding Show_Move, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Move, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Move}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Move]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource EraserTool}"
                              Visibility="{Binding Show_Eraser, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Eraser, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Eraser}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Eraser]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource EraserAreaTool}" 
                              Visibility="{Binding Show_KnifeDelete, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=KnifeDelete, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Knife}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[KnifeDelete]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <Rectangle Style="{StaticResource ToolbarDivider}"/>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource PencilTool}" 
                              Visibility="{Binding Show_Pencil, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Pencil, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Pencil}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Pencil]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource BrushTool}" 
                              Visibility="{Binding Show_Brush, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Brush, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Brush}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Brush]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource MarkerTool}" 
                              Visibility="{Binding Show_Marker, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Marker, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Marker}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Marker]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource BlurTool}" 
                              Visibility="{Binding Show_Blur, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Blur, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Blur}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Blur]}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <Rectangle Style="{StaticResource ToolbarDivider}"/>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource RectangleTool}" 
                              Visibility="{Binding Show_Rectangle, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Rectangle, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Rectangle}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Rectangle]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource CircleTool}" 
                              Visibility="{Binding Show_Ellipse, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Ellipse, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Ellipse}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Ellipse]}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}"
                              Content="{StaticResource LineTool}"
                              Visibility="{Binding Show_Line, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Line, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Line}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Line]}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}"
                              Content="{StaticResource ArrowTool}"
                              Visibility="{Binding Show_Arrow, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Arrow, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Arrow}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Arrow]}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}"
                              Content="{StaticResource TextTool}"
                              Visibility="{Binding Show_Text, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Text, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Text}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Text]}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource FillTool}" 
                              ToolTip="{DynamicResource Tip_Fill}"
                              Visibility="{Binding Show_AreaFill, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding FillEnabled, Mode=TwoWay}"/>

                <Rectangle Style="{StaticResource ToolbarDivider}"/>

                <ToggleButton Style="{StaticResource IconToggleButtonStyle}" 
                              Content="{StaticResource EyedropperTool}" 
                              Visibility="{Binding Show_Eyedropper, Converter={StaticResource BoolToVis}}" 
                              IsChecked="{Binding ActiveTool, Converter={StaticResource ToolConv}, ConverterParameter=Eyedropper, Mode=TwoWay}">
                    <ToggleButton.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Eyedropper}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.ToolHotkeys[Eyedropper]}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </ToggleButton.ToolTip>
                </ToggleButton>

                <Grid Margin="2">
                    <ToggleButton x:Name="ColorPickerButton"
                                  Style="{StaticResource IconToggleButtonStyle}"
                                  ToolTip="{DynamicResource Tip_ColorPalette}"
                                  IsChecked="{Binding IsColorPickerOpen, Mode=TwoWay}"/>

                    <Border Margin="6"
                            CornerRadius="2"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Border.Background>
                            <SolidColorBrush Color="{Binding StrokeColor, Converter={StaticResource RgbaToMediaColorConverter}}"/>
                        </Border.Background>
                    </Border>
                </Grid>

                <Popup x:Name="ColorPickerPopup"
                       IsOpen="{Binding IsColorPickerOpen}"
                       PlacementTarget="{Binding ElementName=ColorPickerButton}"
                       Placement="Bottom"
                       VerticalOffset="12"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       StaysOpen="False">
                    <views:ColorPickerView DataContext="{Binding}"/>
                </Popup>

                <Rectangle Style="{StaticResource ToolbarDivider}"/>

                <Slider x:Name="WidthSlider"
                        Width="80"
                        Margin="0 0 2 0"
                        VerticalAlignment="Center"
                        Minimum="1"
                        Maximum="24"
                        ToolTip="{DynamicResource Tip_StrokeWidth}"
                        Value="{Binding StrokeWidth, Mode=TwoWay}"
                        Visibility="{Binding Show_WidthSlider, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource BlueAccentSliderStyle}"/>

                <Rectangle Style="{StaticResource ToolbarDivider}"
                           Visibility="{Binding Show_WidthSlider, Converter={StaticResource BoolToVis}}"/>

                <Button Style="{StaticResource IconControlButtonStyle}"
                        Content="{StaticResource UndoTool}"
                        Command="{Binding UndoCommand}">
                    <Button.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Undo}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.Hotkeys[Undo].DisplayText}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>

                <Button Style="{StaticResource IconControlButtonStyle}" 
                        Content="{StaticResource RedoTool}"
                        Command="{Binding RedoCommand}">
                    <Button.ToolTip>
                        <ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Tip_Redo}"/>
                                <TextBlock Text=" [" Foreground="#888" Margin="5 0 0 0"/>
                                <TextBlock Text="{Binding Settings.Hotkeys[Redo].DisplayText}"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="]" Foreground="#888"/>
                            </StackPanel>
                        </ToolTip>
                    </Button.ToolTip>
                </Button>

                <Button Style="{StaticResource IconControlButtonStyle}"
                        Content="{StaticResource ClearTool}"
                        ToolTip="{DynamicResource Tip_Clear}"
                        Visibility="{Binding Show_ClearTool, Converter={StaticResource BoolToVis}}"
                        Command="{Binding ClearCommand}"/>

                <Button Style="{StaticResource IconControlButtonStyle}"
                        Content="{StaticResource SaveTool}"
                        ToolTip="{DynamicResource Tip_Save}"
                        Visibility="{Binding Show_SaveTool, Converter={StaticResource BoolToVis}}"
                        Click="Save_Click"/>

                <Button Style="{StaticResource IconControlButtonStyle}"
                        Visibility="{Binding Show_ClipboardTool, Converter={StaticResource BoolToVis}}"
                        Content="{StaticResource ClipboardTool}"
                        ToolTip="{DynamicResource Tip_Copy}"
                        Click="Copy_Click"/>


            </StackPanel>
        </Border>
    </Grid>
</UserControl>