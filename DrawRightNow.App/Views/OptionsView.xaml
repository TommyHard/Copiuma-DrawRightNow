<Window x:Class="DrawRightNow.App.Views.OptionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Width="740" Height="520"
        MinWidth="600" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="#F21E1E22" BorderBrush="#FF4A4A5A" BorderThickness="1" CornerRadius="10" Padding="15"
            MouseLeftButtonDown="Window_MouseDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="{DynamicResource Opt_Title}" FontSize="18" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Content="✕" Width="26" Height="26" Click="Close_Click" Cursor="Hand" Style="{StaticResource FlatButton}"/>
            </Grid>

            <TabControl Grid.Row="1" TabStripPlacement="Left" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#66888888" CornerRadius="3" Margin="2"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Orientation" Value="Vertical">
                                            <Setter Property="Width" Value="10"/>
                                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                                        </Trigger>
                                        <Trigger Property="Orientation" Value="Horizontal">
                                            <Setter Property="Height" Value="10"/>
                                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>

                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#AAA"/>
                        <Setter Property="Margin" Value="0,2,10,2"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Padding="{TemplateBinding Padding}" CornerRadius="6" Background="{TemplateBinding Background}">
                                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#443498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Border" Property="Background" Value="#22FFFFFF"/>
                                            <Setter Property="Foreground" Value="#DDD"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style TargetType="CheckBox">
                        <Setter Property="Foreground" Value="#CCC"/>
                        <Setter Property="Margin" Value="0,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                    <StackPanel Orientation="Horizontal" Background="Transparent">
                                        <Border x:Name="Box" Width="20" Height="20" CornerRadius="4" BorderBrush="#555" BorderThickness="1.5" Background="#1E1E22" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Path x:Name="Check" Stretch="None" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Data="M 4 10 L 8 14 L 15 5" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Box" Property="Background" Value="#3498DB"/>
                                            <Setter TargetName="Box" Property="BorderBrush" Value="#3498DB"/>
                                            <Setter TargetName="Check" Property="Opacity" Value="1"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Box" Property="BorderBrush" Value="#3498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <Style TargetType="TextBlock" x:Key="Lbl">
                        <Setter Property="Foreground" Value="#CCC"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="14"/>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="{DynamicResource Opt_General}">
                    <StackPanel Margin="15,0,0,0">
                        <CheckBox Content="{DynamicResource Opt_Tray}" IsChecked="{Binding ShowInTray, Mode=TwoWay}"/>
                        <Separator Margin="0,15" Background="#444"/>
                        <TextBlock Text="{DynamicResource Opt_Lang}" Foreground="#888" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Русский" Width="90" Height="30" Margin="0,0,10,0" Click="LangRu_Click" Style="{StaticResource FlatButton}"/>
                            <Button Content="English" Width="90" Height="30" Click="LangEn_Click" Style="{StaticResource FlatButton}"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{DynamicResource Opt_Panel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="15,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox Content="{DynamicResource Tip_Pencil}" IsChecked="{Binding Show_Pencil}"/>
                                <CheckBox Content="{DynamicResource Tip_Brush}" IsChecked="{Binding Show_Brush}"/>
                                <CheckBox Content="{DynamicResource Tip_Marker}" IsChecked="{Binding Show_Marker}"/>
                                <CheckBox Content="{DynamicResource Tip_Eraser}" IsChecked="{Binding Show_Eraser}"/>
                                <CheckBox Content="{DynamicResource Tip_Rectangle}" IsChecked="{Binding Show_Rectangle}"/>
                                <CheckBox Content="{DynamicResource Tip_Ellipse}" IsChecked="{Binding Show_Ellipse}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox Content="{DynamicResource Tip_Line}" IsChecked="{Binding Show_Line}"/>
                                <CheckBox Content="{DynamicResource Tip_Arrow}" IsChecked="{Binding Show_Arrow}"/>
                                <CheckBox Content="{DynamicResource Tip_Text}" IsChecked="{Binding Show_Text}"/>
                                <CheckBox Content="{DynamicResource Tip_Knife}" IsChecked="{Binding Show_KnifeDelete}"/>
                                <CheckBox Content="{DynamicResource Tip_Move}" IsChecked="{Binding Show_Move}"/>
                                <CheckBox Content="{DynamicResource Tip_Eyedropper}" IsChecked="{Binding Show_Eyedropper}"/>
                                <CheckBox Content="{DynamicResource Tip_Blur}" IsChecked="{Binding Show_Blur}"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{DynamicResource Opt_GlobalHotkeys}">
                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="{DynamicResource Opt_DescGlobal}" Foreground="#888" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{DynamicResource Opt_ActOverlay}" Style="{StaticResource Lbl}" Grid.Row="0"/>
                            <Button x:Name="Btn_Over" Tag="ToggleOverlay" Style="{StaticResource FlatButton}" Width="150" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Click="GlobalHotkey_Click"/>

                            <TextBlock Text="{DynamicResource Opt_ActDraw}" Style="{StaticResource Lbl}" Grid.Row="1"/>
                            <Button x:Name="Btn_Draw" Tag="ToggleDrawing" Style="{StaticResource FlatButton}" Width="150" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Click="GlobalHotkey_Click"/>

                            <TextBlock Text="{DynamicResource Opt_ActUndo}" Style="{StaticResource Lbl}" Grid.Row="2"/>
                            <Button x:Name="Btn_Undo" Tag="Undo" Style="{StaticResource FlatButton}" Width="150" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Click="GlobalHotkey_Click"/>

                            <TextBlock Text="{DynamicResource Opt_ActRedo}" Style="{StaticResource Lbl}" Grid.Row="3"/>
                            <Button x:Name="Btn_Redo" Tag="Redo" Style="{StaticResource FlatButton}" Width="150" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Click="GlobalHotkey_Click"/>

                            <TextBlock Text="{DynamicResource Opt_ActCopy}" Style="{StaticResource Lbl}" Grid.Row="4"/>
                            <Button x:Name="Btn_Copy" Tag="Copy" Style="{StaticResource FlatButton}" Width="150" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Click="GlobalHotkey_Click"/>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{DynamicResource Opt_ToolHotkeys}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="15,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Opt_DescLocal}" Foreground="#888" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                    <RowDefinition Height="35"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{DynamicResource Tip_Pencil}" Style="{StaticResource Lbl}" Grid.Row="0" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Pencil" Tag="Pencil" Style="{StaticResource FlatButton}" Width="80" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Brush}" Style="{StaticResource Lbl}" Grid.Row="1" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Brush" Tag="Brush" Style="{StaticResource FlatButton}" Width="80" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Marker}" Style="{StaticResource Lbl}" Grid.Row="2" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Marker" Tag="Marker" Style="{StaticResource FlatButton}" Width="80" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Eraser}" Style="{StaticResource Lbl}" Grid.Row="3" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Eraser" Tag="Eraser" Style="{StaticResource FlatButton}" Width="80" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Move}" Style="{StaticResource Lbl}" Grid.Row="4" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Move" Tag="Move" Style="{StaticResource FlatButton}" Width="80" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Blur}" Style="{StaticResource Lbl}" Grid.Row="5" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Blur" Tag="Blur" Style="{StaticResource FlatButton}" Width="80" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Eyedropper}" Style="{StaticResource Lbl}" Grid.Row="6" Grid.Column="0"/>
                                <Button x:Name="Btn_T_Eye" Tag="Eyedropper" Style="{StaticResource FlatButton}" Width="80" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Rectangle}" Style="{StaticResource Lbl}" Grid.Row="0" Grid.Column="3"/>
                                <Button x:Name="Btn_T_Rect" Tag="Rectangle" Style="{StaticResource FlatButton}" Width="80" Grid.Row="0" Grid.Column="4" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Ellipse}" Style="{StaticResource Lbl}" Grid.Row="1" Grid.Column="3"/>
                                <Button x:Name="Btn_T_Ellipse" Tag="Ellipse" Style="{StaticResource FlatButton}" Width="80" Grid.Row="1" Grid.Column="4" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Line}" Style="{StaticResource Lbl}" Grid.Row="2" Grid.Column="3"/>
                                <Button x:Name="Btn_T_Line" Tag="Line" Style="{StaticResource FlatButton}" Width="80" Grid.Row="2" Grid.Column="4" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Arrow}" Style="{StaticResource Lbl}" Grid.Row="3" Grid.Column="3"/>
                                <Button x:Name="Btn_T_Arrow" Tag="Arrow" Style="{StaticResource FlatButton}" Width="80" Grid.Row="3" Grid.Column="4" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Text}" Style="{StaticResource Lbl}" Grid.Row="4" Grid.Column="3"/>
                                <Button x:Name="Btn_T_Text" Tag="Text" Style="{StaticResource FlatButton}" Width="80" Grid.Row="4" Grid.Column="4" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Knife}" Style="{StaticResource Lbl}" Grid.Row="5" Grid.Column="3"/>
                                <Button x:Name="Btn_T_Knife" Tag="KnifeDelete" Style="{StaticResource FlatButton}" Width="80" Grid.Row="5" Grid.Column="4" HorizontalAlignment="Right" Click="ToolHotkey_Click"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>