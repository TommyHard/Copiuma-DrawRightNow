<Window x:Class="DrawRightNow.App.Views.OptionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:vm="clr-namespace:DrawRightNow.Core.ViewModels;assembly=DrawRightNow.Core"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Width="740" Height="520"
        MinWidth="600" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource CoreBorderStyle}" 
            Padding="20" 
            MouseLeftButtonDown="Window_MouseDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" 
                  Margin="0 0 0 20">
                <TextBlock Text="{DynamicResource Opt_Title}" 
                           FontSize="18" 
                           Foreground="{StaticResource ToolbarForeground}" 
                           VerticalAlignment="Center"/>
                <Button Width="30" Height="30" 
                        HorizontalAlignment="Right" 
                        Content="{StaticResource ButtonClose}" 
                        ToolTip="{DynamicResource Tip_CloseWindow}" 
                        Style="{StaticResource IconControlButtonStyle}" 
                        Click="Close_Click"/>
            </Grid>

            <TabControl Grid.Row="1" 
                        TabStripPlacement="Left" 
                        Background="Transparent" 
                        BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Width"                        Value="220"/>
                        <Setter Property="Background"                   Value="Transparent"/>
                        <Setter Property="Foreground"                   Value="#DFE3E6"/>
                        <Setter Property="Margin"                       Value="0 2 15 2"/>
                        <Setter Property="Padding"                      Value="16 12 32 12"/>
                        <Setter Property="FontSize"                     Value="14"/>
                        <Setter Property="Cursor"                       Value="Hand"/>
                        <Setter Property="FocusVisualStyle"             Value="{StaticResource FocusVisualStyle}"/>
                        <Setter Property="HorizontalContentAlignment"   Value="Stretch"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">

                                    <Grid Background="Transparent" 
                                          Margin="0 0 10 0">

                                        <Border x:Name="HoverBg"
                                                Background="#3E3E3E" 
                                                Opacity="0"/>
                                        <Border x:Name="ActiveBg"
                                                Background="#009BFF" 
                                                Opacity="0"/>
                                        <Border Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header"
                                                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"     Value="True">
                                            <Setter Property="Panel.ZIndex" Value="1"/>
                                            <Setter Property="Foreground"   Value="White"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="HoverBg" 
                                                                         Storyboard.TargetProperty="Opacity" 
                                                                         To="1" 
                                                                         Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="HoverBg" 
                                                                         Storyboard.TargetProperty="Opacity" 
                                                                         To="0" 
                                                                         Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>

                                        <Trigger Property="IsSelected"      Value="True">
                                            <Setter Property="Panel.ZIndex" Value="2"/>
                                            <Setter Property="Foreground"   Value="White"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ActiveBg" 
                                                                         Storyboard.TargetProperty="Opacity" 
                                                                         To="1" 
                                                                         Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ActiveBg" 
                                                                         Storyboard.TargetProperty="Opacity" 
                                                                         To="0" 
                                                                         Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="{DynamicResource Opt_General}">
                    <StackPanel Margin="15 0 0 0">
                        <TextBlock Text="{DynamicResource Opt_Lang}" 
                                   Foreground="{StaticResource ToolbarForeground}" 
                                   Opacity=".7" 
                                   Margin="0 0 0 15"
                                   Cursor="Arrow"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Русский" 
                                    Width="90" Height="30" 
                                    Margin="0 0 10 0" 
                                    Click="LangRu_Click" 
                                    Style="{StaticResource FlatButton}"/>
                            <Button Content="English" 
                                    Width="90" Height="30" 
                                    Click="LangEn_Click" 
                                    Style="{StaticResource FlatButton}"/>
                        </StackPanel>
                        
                        <Rectangle Height="2" 
                                   Margin="0 15" 
                                   Fill="{StaticResource ToolbarBorder}"/>
                        
                        <CheckBox Content="{DynamicResource Opt_Tray}" 
                                  HorizontalAlignment="Left" 
                                  IsChecked="{Binding ShowInTray, Mode=TwoWay}"
                                  Style="{StaticResource TextControlCheckBoxStyle}"/>
                        <CheckBox Content="{DynamicResource Opt_RememberPosition}"
                                  HorizontalAlignment="Left" 
                                  IsChecked="{Binding RememberToolbarPosition, Mode=TwoWay}" 
                                  Style="{StaticResource TextControlCheckBoxStyle}"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{DynamicResource Opt_Panel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" 
                                  Margin="15 0 0 0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Opt_ToolsVisibility}" 
                                       Foreground="{StaticResource ToolbarForeground}" 
                                       Opacity=".7" 
                                       Margin="0 0 0 15"
                                       Cursor="Arrow"/>
                            <CheckBox Content="{DynamicResource Tip_Move}" 
                                      Tag="{StaticResource MoveTool}"
                                      IsChecked="{Binding Show_Move, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Eraser}" 
                                      Tag="{StaticResource EraserTool}"
                                      IsChecked="{Binding Show_Eraser, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Knife}" 
                                      Tag="{StaticResource EraserAreaTool}"
                                      IsChecked="{Binding Show_KnifeDelete, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Pencil}"
                                      Tag="{StaticResource PencilTool}"
                                      IsChecked="{Binding Show_Pencil, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Brush}" 
                                      Tag="{StaticResource BrushTool}"
                                      IsChecked="{Binding Show_Brush, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Marker}" 
                                      Tag="{StaticResource MarkerTool}"
                                      IsChecked="{Binding Show_Marker, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Blur}" 
                                      Tag="{StaticResource BlurTool}"
                                      IsChecked="{Binding Show_Blur, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Rectangle}"
                                      Tag="{StaticResource RectangleTool}"
                                      IsChecked="{Binding Show_Rectangle, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Ellipse}" 
                                      Tag="{StaticResource CircleTool}"
                                      IsChecked="{Binding Show_Ellipse, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Line}" 
                                      Tag="{StaticResource LineTool}"
                                      IsChecked="{Binding Show_Line, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Arrow}"
                                      Tag="{StaticResource ArrowTool}"
                                      IsChecked="{Binding Show_Arrow, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Text}" 
                                      Tag="{StaticResource TextTool}"
                                      IsChecked="{Binding Show_Text, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Fill}"
                                      Tag="{StaticResource FillTool}"
                                      IsChecked="{Binding Show_AreaFill, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Eyedropper}"
                                      Tag="{StaticResource EyedropperTool}"
                                      IsChecked="{Binding Show_Eyedropper, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>

                            <!-- Видимость глобальных инструментов -->
                            <CheckBox Content="{DynamicResource Tip_StrokeWidth}" 
                                      IsChecked="{Binding Show_WidthSlider, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Clear}"
                                      Tag="{StaticResource ClearTool}"
                                      IsChecked="{Binding Show_ClearTool, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Save}" 
                                      Tag="{StaticResource SaveTool}"
                                      IsChecked="{Binding Show_SaveTool, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_Copy}" 
                                      Tag="{StaticResource ClipboardTool}"
                                      IsChecked="{Binding Show_ClipboardTool, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>

                            <!-- Видимость инструментов SecondaryToolbarView -->
                            <CheckBox Content="{DynamicResource Opt_ChangePosition}" 
                                      Tag="{StaticResource ChangePositionTool}"
                                      IsChecked="{Binding Show_ChangePositionTool, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                            <CheckBox Content="{DynamicResource Tip_ToolbarTranslucent}" 
                                      Tag="{StaticResource ButtonFadingMode}"
                                      IsChecked="{Binding Show_FadingMode, Mode=TwoWay}" 
                                      Style="{StaticResource TextControlCheckBoxStyle}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{DynamicResource Opt_GlobalHotkeys}">
                    <StackPanel Margin="15 0 0 0" 
                                MaxWidth="540" 
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="{DynamicResource Opt_DescGlobal}" 
                                   Foreground="{StaticResource ToolbarForeground}" 
                                   Opacity=".7" 
                                   Margin="0 0 0 15"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="45"/>
                                <RowDefinition Height="45"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="400"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{DynamicResource Opt_ActOverlay}" 
                                       Grid.Row="0" Grid.Column="0" 
                                       VerticalAlignment="Center"/>
                            <Button x:Name="Btn_Over" 
                                    Tag="ToggleOverlay" 
                                    Style="{StaticResource FlatButton}" 
                                    HorizontalAlignment="Stretch" 
                                    Grid.Row="0" 
                                    Grid.Column="2" 
                                    Click="GlobalHotkey_Click"/>

                            <TextBlock Text="{DynamicResource Opt_ActUndo}" 
                                       Grid.Row="1" Grid.Column="0" 
                                       VerticalAlignment="Center"/>
                            <Button x:Name="Btn_Undo" 
                                    Tag="Undo" 
                                    Style="{StaticResource FlatButton}" 
                                    HorizontalAlignment="Stretch" 
                                    Grid.Row="1" Grid.Column="2" 
                                    Click="GlobalHotkey_Click"/>

                            <TextBlock Text="{DynamicResource Opt_ActRedo}" 
                                       Grid.Row="2" Grid.Column="0" 
                                       VerticalAlignment="Center"/>
                            <Button x:Name="Btn_Redo" 
                                    Tag="Redo" 
                                    Style="{StaticResource FlatButton}" 
                                    HorizontalAlignment="Stretch" 
                                    Grid.Row="2" Grid.Column="2" 
                                    Click="GlobalHotkey_Click"/>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{DynamicResource Opt_ToolHotkeys}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" 
                                  Margin="15 0 0 0">
                        <StackPanel MaxWidth="540" 
                                    HorizontalAlignment="Stretch">
                            <TextBlock Text="{DynamicResource Opt_DescLocal}" 
                                       Foreground="{StaticResource ToolbarForeground}" 
                                       Opacity=".7" 
                                       Margin="0 0 0 15"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="400"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{DynamicResource Tip_Pencil}" 
                                           Grid.Row="0" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Pencil" 
                                        Tag="Pencil" 
                                        Style="{StaticResource FlatButton}" 
                                        HorizontalAlignment="Stretch" 
                                        Grid.Row="0" Grid.Column="2" 
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Brush}" 
                                           Grid.Row="1" Grid.Column="0" 
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Brush" 
                                        Tag="Brush" 
                                        Style="{StaticResource FlatButton}" 
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="1" Grid.Column="2" 
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Marker}" 
                                           Grid.Row="2" Grid.Column="0" 
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Marker" 
                                        Tag="Marker" 
                                        Style="{StaticResource FlatButton}" 
                                        HorizontalAlignment="Stretch" 
                                        Grid.Row="2" Grid.Column="2" 
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Eraser}" 
                                           Grid.Row="3" Grid.Column="0" 
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Eraser" 
                                        Tag="Eraser" 
                                        Style="{StaticResource FlatButton}" 
                                        HorizontalAlignment="Stretch" 
                                        Grid.Row="3" Grid.Column="2" 
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Rectangle}"
                                           Grid.Row="4" Grid.Column="0" 
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Rect" 
                                        Tag="Rectangle" 
                                        Style="{StaticResource FlatButton}" 
                                        HorizontalAlignment="Stretch" 
                                        Grid.Row="4" Grid.Column="2" 
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Ellipse}" 
                                           Grid.Row="5" Grid.Column="0" 
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Ellipse" 
                                        Tag="Ellipse" 
                                        Style="{StaticResource FlatButton}" 
                                        HorizontalAlignment="Stretch" 
                                        Grid.Row="5" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Line}"
                                           Grid.Row="6" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Line"
                                        Tag="Line"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="6" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Arrow}"
                                           Grid.Row="7" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Arrow"
                                        Tag="Arrow"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="7" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Text}"
                                           Grid.Row="8" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Text"
                                        Tag="Text"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="8" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Knife}"
                                           Grid.Row="9" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Knife"
                                        Tag="KnifeDelete"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="9" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Move}"
                                           Grid.Row="10" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Move"
                                        Tag="Move"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="10" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Eyedropper}"
                                           Grid.Row="11" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Eye"
                                        Tag="Eyedropper"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="11" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>

                                <TextBlock Text="{DynamicResource Tip_Blur}"
                                           Grid.Row="12" Grid.Column="0"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="Btn_T_Blur"
                                        Tag="Blur"
                                        Style="{StaticResource FlatButton}"
                                        HorizontalAlignment="Stretch"
                                        Grid.Row="12" Grid.Column="2"
                                        Click="ToolHotkey_Click"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>