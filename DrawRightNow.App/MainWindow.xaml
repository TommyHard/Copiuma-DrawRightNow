<Window x:Class="DrawRightNow.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:render="clr-namespace:DrawRightNow.Rendering.Controls;assembly=DrawRightNow.Rendering"
        xmlns:views="clr-namespace:DrawRightNow.App.Views"
        Title="DrawRightNow"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid x:Name="RootGrid"
          Background="Transparent">

        <!-- Чёрная подложка с регулируемой прозрачностью.
             Opacity управляется слайдером OverlayDimAlpha (0-100 -> 0-1) -->
        <Border x:Name="DimLayer"
                IsHitTestVisible="False"
                Background="Black"
                Opacity="{Binding OverlayDimOpacity, Mode=OneWay}"/>

        <!-- Холст рисования на весь экран. IsHitTestVisible держим всегда True:
             click-through контролируется на уровне Win32 (WM_NCHITTEST) -->
        <render:DrawingSurface x:Name="Surface"
                               ViewModel="{Binding}"/>

        <!-- Горизонтальная панель снизу -->
        <Grid x:Name="ToolbarHost"
              VerticalAlignment="Bottom"
              HorizontalAlignment="Center"
              Margin="0 0 0 32"
              Background="Transparent"
              MouseLeftButtonDown="ToolbarHost_MouseDown" 
              MouseMove="ToolbarHost_MouseMove" 
              MouseLeftButtonUp="ToolbarHost_MouseUp">

            <Grid.RenderTransform>
                <TranslateTransform x:Name="ToolbarTransform"/>
            </Grid.RenderTransform>

            <views:ToolbarView x:Name="Toolbar" DataContext="{Binding}"/>
        </Grid>

        <!-- Угловой бейдж — гарантия того, что overlay видим, даже
             если пользователь ещё ничего не нарисовал -->
        <Border x:Name="ActiveBadge"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0 0 16 16"
                Padding="10 4"
                CornerRadius="2"
                Background="#AA1E1E22"
                BorderBrush="#FF3498DB"
                BorderThickness="1"
                IsHitTestVisible="False">
            <TextBlock Text="DrawRightNow ●" 
                       Foreground="#FFEFEFEF" 
                       FontSize="11"/>
        </Border>

        <Canvas x:Name="EyedropperOverlay"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Grid x:Name="EyedropperPreview">
                <Line X1="-12" Y1="0" X2="-3"  Y2="0" Stroke="White" StrokeThickness="1"/>
                <Line X1="3"   Y1="0" X2="12"  Y2="0" Stroke="White" StrokeThickness="1"/>
                <Line X1="0"   Y1="-12" X2="0" Y2="-3" Stroke="White" StrokeThickness="1"/>
                <Line X1="0"   Y1="3"   X2="0" Y2="12" Stroke="White" StrokeThickness="1"/>
                <Border x:Name="EyedropperSwatch"
                        Width="55" Height="55"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="14 14 0 0"
                        BorderBrush="White" 
                        BorderThickness="2"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <UniformGrid x:Name="PixelGrid" 
                                     Rows="5" Columns="5"/>
                        <Border BorderBrush="Red" 
                                BorderThickness="1" 
                                Width="11" Height="11" 
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Canvas>

        <!-- Инлайн-редактор для TextTool -->
        <Canvas x:Name="TextEditorLayer"
                IsHitTestVisible="True"
                Background="{x:Null}">
            <TextBox x:Name="TextEditor"
                     Visibility="Collapsed"
                     MinWidth="80"
                     BorderBrush="#FF3498DB"
                     BorderThickness="1"
                     Background="#33000000"
                     Foreground="White"
                     CaretBrush="White"
                     Padding="2 0"
                     AcceptsReturn="False"
                     KeyDown="TextEditor_KeyDown"
                     PreviewMouseWheel="TextEditor_PreviewMouseWheel"
                     LostKeyboardFocus="TextEditor_LostFocus"/>
        </Canvas>

    </Grid>
</Window>